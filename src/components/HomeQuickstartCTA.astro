---
import GrowthEvent from './GrowthEvent.astro';

interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;
const isZh = lang === 'zh';

const headline = isZh ? '3 分钟开始使用 OpenClaw' : 'Get started with OpenClaw in 3 minutes';
const sub = isZh
  ? '安装 → 首次运行 → 验证。把“看过”变成“跑起来”。'
  : 'Install → First run → Verify. Turn reading into running.';

const steps = isZh
  ? [
      { title: '安装', body: '安装 OpenClaw 并确认 gateway 正常运行。', code: 'npm i -g openclaw' },
      { title: '首跑', body: '检查 Gateway 状态（确保服务在线）。', code: 'openclaw gateway status' },
      { title: '验证', body: '跑一次 doctor，确认环境 OK。', code: 'openclaw doctor' },
    ]
  : [
      { title: 'Install', body: 'Install OpenClaw and ensure the gateway can run.', code: 'npm i -g openclaw' },
      { title: 'First run', body: 'Check the Gateway is up.', code: 'openclaw gateway status' },
      { title: 'Verify', body: 'Run a quick health check.', code: 'openclaw doctor' },
    ];

const primaryHref = isZh
  ? '/zh/blog/openclaw-install-first-run-error-troubleshooting/'
  : '/en/blog/openclaw-install-first-run-error-troubleshooting/';

const secondaryHref = isZh
  ? '/zh/blog/what-is-openclaw/'
  : '/en/blog/what-is-openclaw/';

const primaryText = isZh ? '安装与首跑指南 →' : 'Install & first run guide →';
const secondaryText = isZh ? '先了解 OpenClaw 是什么 →' : 'What is OpenClaw? →';

const tgHref = 'https://t.me/openclaw';
const tgText = isZh ? '加入 Telegram 社群 →' : 'Join Telegram community →';
const templateText = isZh ? '复制问题模板' : 'Copy issue template';

const copyLabel = isZh ? '复制' : 'Copy';
const verifyLabel = isZh ? '验证' : 'Verify';
const verifyingLabel = isZh ? '验证中…' : 'Verifying…';
const verifiedLabel = isZh ? '已验证' : 'Verified';

const verifyHint = isZh
  ? '已复制。5 秒后粘贴你执行命令的输出（仅本地验证，不会上报）。'
  : 'Copied. In 5s, paste the output of the command you ran (local-only, not sent anywhere).';

const issueTemplate = isZh
  ? `【问题概述】一句话描述你遇到的现象

【环境】
- 系统：
- 安装方式：
- OpenClaw 版本：

【我执行了什么】
- 命令：
- 期望结果：
- 实际结果：

【补充】可选日志（请先脱敏，勿粘贴密钥）`
  : `Issue summary (one sentence)

Environment
- OS:
- Install method:
- OpenClaw version:

What I ran
- Command:
- Expected:
- Actual:

Optional logs (redact secrets before pasting)`;
---

<section class="oc-cta" aria-label={headline}>
  <div class="oc-cta__inner">
    <div class="oc-cta__left">
      <h2 class="oc-cta__h">{headline}</h2>
      <p class="oc-cta__p">{sub}</p>

      <div class="oc-cta__actions">
        <a
          class="oc-cta__btn oc-cta__btn--primary"
          href={primaryHref}
          data-growth="cta-primary"
          data-lang={lang}
        >
          {primaryText}
        </a>
        <a
          class="oc-cta__btn oc-cta__btn--ghost"
          href={secondaryHref}
          data-growth="cta-secondary"
          data-lang={lang}
        >
          {secondaryText}
        </a>
        <a
          class="oc-cta__btn oc-cta__btn--telegram"
          href={tgHref}
          target="_blank"
          rel="noopener noreferrer"
          data-growth="tg"
          data-lang={lang}
        >
          {tgText}
        </a>
        <button
          class="oc-cta__btn oc-cta__btn--template"
          type="button"
          data-template={issueTemplate}
          data-growth="issue-template"
          data-lang={lang}
        >
          {templateText}
        </button>
      </div>

      <div class="oc-cta__steps">
        {steps.map((s, idx) => (
          <div class="oc-cta__step">
            <div class="oc-cta__stepTitle">{idx + 1}. {s.title}</div>
            <div class="oc-cta__stepBody">{s.body}</div>
            <div class="oc-cta__codeRow">
              <code class="oc-cta__code" data-code={s.code}>{s.code}</code>
              <button
                class="oc-cta__copy"
                type="button"
                data-copy={s.code}
                data-growth="copy"
                data-lang={lang}
              >
                {copyLabel}
              </button>
              {(s.code.includes('openclaw gateway status') || s.code.includes('openclaw doctor')) && (
                <button
                  class="oc-cta__verify"
                  type="button"
                  data-verify={s.code}
                  data-growth="verify"
                  data-lang={lang}
                >
                  {verifyLabel}
                </button>
              )}
            </div>
            {(s.code.includes('openclaw gateway status') || s.code.includes('openclaw doctor')) && (
              <div class="oc-cta__verifyRow" aria-live="polite" data-verify-row>
                <div class="oc-cta__verifyHint" data-verify-hint style="display:none">{verifyHint}</div>
                <input class="oc-cta__verifyInput" data-verify-input placeholder={isZh ? '粘贴输出（可选）' : 'Paste output (optional)'} style="display:none" />
              </div>
            )}
          </div>
        ))}
      </div>
      <div class="oc-cta__hint">
        {isZh ? '提示：复制后建议立刻执行第 2 步验证服务是否在线。' : 'Tip: after copying, run step 2 to confirm the gateway is up.'}
      </div>
    </div>
  </div>
</section>

<GrowthEvent name="home_cta_render" lang={lang} />

<script type="module">
  const onClick = (e) => {
    const a = e.target?.closest?.('a[data-growth]');
    if (a) {
      const growthKind = a.getAttribute('data-growth');
      const detail = {
        name: growthKind === 'tg' ? 'home_cta_tg_click' : 'home_cta_click',
        kind: growthKind,
        lang: a.getAttribute('data-lang') || undefined,
        href: a.getAttribute('href') || undefined,
      };
      console.log('[growth:event]', detail);
      window.dispatchEvent(new CustomEvent('openclaw:growth', { detail }));

      if (growthKind === 'tg') {
        const openDetail = {
          name: 'home_cta_tg_open',
          kind: growthKind,
          lang: a.getAttribute('data-lang') || undefined,
          href: a.getAttribute('href') || undefined,
        };
        setTimeout(() => {
          console.log('[growth:event]', openDetail);
          window.dispatchEvent(new CustomEvent('openclaw:growth', { detail: openDetail }));
        }, 80);
      }
    }

    const templateBtn = e.target?.closest?.('button[data-template]');
    if (templateBtn) {
      const text = templateBtn.getAttribute('data-template') || '';
      const lang = templateBtn.getAttribute('data-lang') || undefined;
      const done = () => {
        const isZh = (lang || '').startsWith('zh');
        templateBtn.textContent = isZh ? '已复制模板' : 'Template copied';
        setTimeout(() => (templateBtn.textContent = isZh ? '复制问题模板' : 'Copy issue template'), 1400);
      };

      navigator.clipboard?.writeText(text).then(done).catch(() => {
        try {
          const ta = document.createElement('textarea');
          ta.value = text;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          ta.remove();
          done();
        } catch (_) {}
      });

      const detail = {
        name: 'home_cta_issue_template_copy',
        lang,
        kind: 'issue-template',
      };
      console.log('[growth:event]', detail);
      window.dispatchEvent(new CustomEvent('openclaw:growth', { detail }));
    }

    const btn = e.target?.closest?.('button[data-copy]');
    if (btn) {
      const text = btn.getAttribute('data-copy') || '';
      const detail = {
        name: 'home_cta_copy',
        lang: btn.getAttribute('data-lang') || undefined,
        text,
      };
      const done = () => {
        const wasZh = (btn.textContent || '').includes('复制') || (btn.textContent || '').includes('已复制');
        btn.textContent = wasZh ? '已复制' : 'Copied';
        setTimeout(() => (btn.textContent = wasZh ? '复制' : 'Copy'), 1200);
      };

      navigator.clipboard?.writeText(text).then(done).catch(() => {
        try {
          const ta = document.createElement('textarea');
          ta.value = text;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          ta.remove();
          done();
        } catch (_) {}
      });

      console.log('[growth:event]', detail);
      window.dispatchEvent(new CustomEvent('openclaw:growth', { detail }));

      // EXP-051: arm verify micro-interaction (local-only)
      const root = btn.closest('.oc-cta__step');
      const verifyBtn = root?.querySelector('button[data-verify]');
      const hintEl = root?.querySelector('[data-verify-hint]');
      const inputEl = root?.querySelector('[data-verify-input]');
      if (verifyBtn && hintEl && inputEl) {
        hintEl.style.display = 'block';
        inputEl.style.display = 'block';
        inputEl.focus();
        setTimeout(() => {
          if (document.activeElement !== inputEl) inputEl.focus();
        }, 5200);
      }
    }

    const vbtn = e.target?.closest?.('button[data-verify]');
    if (vbtn) {
      const cmd = vbtn.getAttribute('data-verify') || '';
      const lang = vbtn.getAttribute('data-lang') || undefined;
      const root = vbtn.closest('.oc-cta__step');
      const hintEl = root?.querySelector('[data-verify-hint]');
      const inputEl = root?.querySelector('[data-verify-input]');
      const isZh = (lang || '').startsWith('zh');

      // Copy first
      const copy = () => navigator.clipboard?.writeText(cmd).catch(() => {
        try {
          const ta = document.createElement('textarea');
          ta.value = cmd;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          ta.remove();
        } catch (_) {}
      });

      vbtn.textContent = isZh ? '验证中…' : 'Verifying…';
      copy();

      if (hintEl && inputEl) {
        hintEl.style.display = 'block';
        inputEl.style.display = 'block';
        inputEl.focus();
      }

      const detail = { name: 'home_cta_verify_start', lang, cmd };
      console.log('[growth:event]', detail);
      window.dispatchEvent(new CustomEvent('openclaw:growth', { detail }));

      // 5s “echo” window: user pastes output; we just mark verified locally.
      setTimeout(() => {
        const val = (inputEl?.value || '').trim();
        const ok = val.length > 0;
        vbtn.textContent = ok ? (isZh ? '已验证' : 'Verified') : (isZh ? '验证' : 'Verify');
        if (ok) {
          const d2 = { name: 'home_cta_verify_echo', lang, cmd, bytes: val.length };
          console.log('[growth:event]', d2);
          window.dispatchEvent(new CustomEvent('openclaw:growth', { detail: d2 }));
        }
        setTimeout(() => {
          vbtn.textContent = isZh ? '验证' : 'Verify';
        }, 1400);
      }, 5000);
    }
  };

  document.addEventListener('click', onClick);

  // Scroll exposure (once)
  let fired = false;
  const el = document.querySelector('.oc-cta');
  if (el) {
    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!fired && entry.isIntersecting) {
          fired = true;
          const detail = { name: 'home_cta_view', lang: document.documentElement.lang };
          console.log('[growth:event]', detail);
          window.dispatchEvent(new CustomEvent('openclaw:growth', { detail }));
          io.disconnect();
        }
      }
    }, { threshold: 0.35 });
    io.observe(el);
  }
</script>

<style>
  .oc-cta { margin: 1.25rem 0 1.75rem; }
  .oc-cta__inner {
    background: linear-gradient(135deg, rgba(79,70,229,0.10), rgba(99,102,241,0.04));
    border: 1px solid rgba(79,70,229,0.25);
    border-radius: 14px;
    padding: 16px;
  }
  .oc-cta__h { margin: 0 0 6px; font-size: 1.4rem; }
  .oc-cta__p { margin: 0 0 12px; color: var(--text-muted); }
  .oc-cta__actions { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
  .oc-cta__btn {
    display: inline-block;
    padding: 10px 12px;
    border-radius: 10px;
    font-weight: 700;
    border: 1px solid var(--border);
  }
  .oc-cta__btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .oc-cta__btn--primary:hover { background: var(--accent-hover); color: #fff; }
  .oc-cta__btn--ghost { background: #fff; color: var(--text); }
  .oc-cta__btn--ghost:hover { background: var(--card-hover); }
  .oc-cta__btn--telegram { background: rgba(14,165,233,0.12); color: var(--text); border-color: rgba(14,165,233,0.35); }
  .oc-cta__btn--telegram:hover { background: rgba(14,165,233,0.18); }
  .oc-cta__btn--template { background: rgba(245,158,11,0.10); color: var(--text); border-color: rgba(245,158,11,0.35); cursor: pointer; }
  .oc-cta__btn--template:hover { background: rgba(245,158,11,0.16); }

  .oc-cta__steps { display: grid; gap: 10px; }
  .oc-cta__step { background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 12px; }
  .oc-cta__stepTitle { font-weight: 700; margin-bottom: 4px; }
  .oc-cta__stepBody { color: var(--text-muted); margin-bottom: 8px; }
  .oc-cta__codeRow { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .oc-cta__code { padding: 6px 10px; }
  .oc-cta__copy {
    border-radius: 10px;
    padding: 7px 10px;
    border: 1px solid rgba(79,70,229,0.35);
    background: rgba(79,70,229,0.08);
    font-weight: 700;
    cursor: pointer;
  }
  .oc-cta__copy:hover { background: rgba(79,70,229,0.12); }

  .oc-cta__verify {
    border-radius: 10px;
    padding: 7px 10px;
    border: 1px solid rgba(16,185,129,0.35);
    background: rgba(16,185,129,0.08);
    font-weight: 800;
    cursor: pointer;
  }
  .oc-cta__verify:hover { background: rgba(16,185,129,0.12); }

  .oc-cta__verifyRow { margin-top: 8px; }
  .oc-cta__verifyHint { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 6px; }
  .oc-cta__verifyInput {
    width: min(680px, 100%);
    padding: 9px 10px;
    border-radius: 10px;
    border: 1px solid var(--border);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.95rem;
  }

  .oc-cta__hint { margin-top: 10px; font-size: 0.9rem; color: var(--text-muted); }
</style>
