---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeQuickstartCTA from '../../components/HomeQuickstartCTA.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'zh')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="首页" lang="zh">
  <h1>🤖 AI 智能体资讯站</h1>
  <p style="font-size:1.1rem; margin:1rem 0;">聚焦 AI 智能体相关资讯、实操教程与工具指南。当前会有较多 OpenClaw 内容，但不局限于 OpenClaw。</p>

  <img src="/images/home-hero-cartoon.png" alt="OpenClaw Hub 手绘介绍图" style="width:100%; max-width:1100px; border-radius:16px; margin:0.5rem 0 1.25rem; display:block;" />
  
  
  <HomeQuickstartCTA lang="zh" />
<p style="margin:0 0 1rem;"><a href="/zh/daily/">📰 只看科技日报（连续阅读）</a> · <a href="/zh/daily/rss.xml">📡 RSS 订阅</a> · <a href="/coding/">⚡ Team Vibe Coding 子站</a></p>
  <h2>最新文章</h2>
  {posts.slice(0, 20).map(post => {
    const slug = post.id.replace(/^zh\//, '').replace(/\.md$/, '');
    return (
      <a href={`/zh/blog/${slug}/`} style="text-decoration:none; color:inherit;">
        <div class="card" style="cursor:pointer;">
          <h3 style="margin-top:0;">{post.data.title}</h3>
          <p style="color:#999; margin:0.3rem 0;">{post.data.description}</p>
          <div style="color:#666; font-size:0.85rem;">
            {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
            {' · '}
            {post.data.tags.map(tag => <span class="tag" style="margin-right:4px;">{tag}</span>)}
          </div>
        </div>
      </a>
    );
  })}
</BaseLayout>
